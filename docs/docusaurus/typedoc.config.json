{
    "$schema": "https://typedoc-plugin-markdown.org/schema.json",
    "entryPointStrategy": "expand",
    "entryPoints": [
        "../../src/plugin.ts"
    ],
    "extends": [
        "typedoc-config-nick2bad4u/typedoc.json"
    ],
    "gitRemote": "origin",
    "gitRevision": "main",
    "hostedBaseUrl": "https://nick2bad4u.github.io/eslint-plugin-tombi/",
    "json": "docs/typedoc.json",
    "logLevel": "Info",
    "name": "eslint-plugin-tombi Documentation",
    "out": "site-docs/developer/api",
    "readme": "none",
    "tsconfig": "tsconfig.typedoc.json",
    "warnOnUnstableDtLink": false
}
